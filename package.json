{
  "name": "themistec",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Plataforma de gestão jurídica para advogados autônomos",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:e2e": "eslint e2e playwright.config.ts --ext .ts",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:rls": "node scripts/verify-rls.mjs",
    "validate": "npm run typecheck && npm run lint && npm run lint:e2e && npm run test",
    "harness": "npm run validate"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.5",
    "@types/pizzip": "^3.0.5",
    "docxtemplater": "^3.69.0",
    "file-saver": "^2.0.5",
    "idb-keyval": "^6.3.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pizzip": "^3.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "sonner": "^2.0.7",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "20.19.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@typescript-eslint/eslint-plugin": "8.34.0",
    "@typescript-eslint/parser": "8.34.0",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.5.2",
    "eslint": "9.29.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "26.1.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "5.8.3",
    "vitest": "^3.2.7"
  }
